generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          String         @default("user")
  teamId        String?
  team          Team?          @relation("TeamManagers", fields: [teamId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id             String    @id @default(cuid())
  name           String
  shortName      String
  slug           String    @unique
  logo           String
  city           String
  founded        Int
  manager        String
  stadium        String
  primaryColor   String
  secondaryColor String
  description    String
  managerUsers   User[]    @relation("TeamManagers")
  awayFixtures   Fixture[] @relation("AwayTeam")
  homeFixtures   Fixture[] @relation("HomeTeam")
  players        Player[]
  standing       Standing?
}

model Player {
  id              String       @id @default(cuid())
  name            String
  teamId          String
  position        String
  number          Int
  nationality     String
  nationalityFlag String       @default("🇮🇳")
  age             Int
  photo           String
  goals           Int          @default(0)
  assists         Int          @default(0)
  matches         Int          @default(0)
  yellowCards     Int          @default(0)
  redCards        Int          @default(0)
  cleanSheets     Int          @default(0)
  rating          Float        @default(6.0)
  Fixture         Fixture[]
  MatchEvent      MatchEvent[]
  team            Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Fixture {
  id                      String       @id @default(cuid())
  homeTeamId              String
  awayTeamId              String
  date                    String
  time                    String
  venue                   String
  matchday                Int
  status                  String
  homeScore               Int?
  awayScore               Int?
  attendance              Int?         @default(0)
  goalScorers             String?      @default("")
  manOfTheMatchId         String?
  matchReport             String?      @default("")
  redCards                String?      @default("")
  referee                 String?      @default("")
  yellowCards             String?      @default("")
  predictionWinnerContact String?
  predictionWinnerName    String?
  awayTeam                Team         @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  homeTeam                Team         @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  Player                  Player?      @relation(fields: [manOfTheMatchId], references: [id])
  MatchEvent              MatchEvent[]
  Prediction              Prediction[]
}

model Standing {
  id             String @id @default(cuid())
  position       Int
  teamId         String @unique
  played         Int    @default(0)
  won            Int    @default(0)
  drawn          Int    @default(0)
  lost           Int    @default(0)
  goalsFor       Int    @default(0)
  goalsAgainst   Int    @default(0)
  goalDifference Int    @default(0)
  points         Int    @default(0)
  form           String
  positionChange String
  team           Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model NewsArticle {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String
  category      String
  author        String
  coverImage    String
  publishedAt   DateTime @default(now())
  featured      Boolean  @default(false)
  tags          String
  manOfTheMatch String?  @default("")
}

model GalleryImage {
  id      String  @id @default(cuid())
  url     String
  caption String
  matchId String?
  tags    String
  width   Int     @default(1200)
  height  Int     @default(800)
}

model Sponsor {
  id          String  @id @default(cuid())
  name        String
  logo        String
  url         String
  tier        String
  description String?
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}

model MatchEvent {
  id        String    @id
  fixtureId String
  playerId  String
  type      EventType
  minute    Int?
  createdAt DateTime  @default(now())
  Fixture   Fixture   @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  Player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Prediction {
  id              String   @id
  fixtureId       String
  voterName       String
  voterContact    String
  predictedResult String
  createdAt       DateTime @default(now())
  Fixture         Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, voterContact])
}

enum EventType {
  GOAL
  YELLOW_CARD
  RED_CARD
}

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String?
  createdAt DateTime @default(now())
}
